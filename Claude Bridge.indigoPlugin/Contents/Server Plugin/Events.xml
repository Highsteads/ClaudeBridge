<?xml version="1.0"?>
<!--
    Claude Bridge Plugin Events
    ===========================
    Lets Claude fire Indigo Triggers with structured payload data using the
    2025.1+ eventData mechanism.

    Workflow:
      1. Create a Trigger:  Type = Plugin → Claude Bridge → Claude Event
      2. (Optional) Filter on a specific event name: add a Condition of type
         "Script" and test the event_data dict, e.g.
            return event_data.get("name") == "sunset_routine"
      3. In the Trigger's actions, reference the payload via Indigo's event-data
         substitution (note the quoted-key %%e:"..."%% form — this is Indigo's
         real syntax; there is no %%eventData:...%% prefix):
            %%e:"name"%%       — the event name string
            %%e:"data"%%       — JSON-serialised payload
            %%e:"source"%%     — origin label (default "claude")
         (Or use "Insert Event Data into Variable" from the actions list.)
      4. From Claude, call the MCP tool: fire_indigo_event(name, data, source)
-->
<Events>

    <Event id="claudeEvent">
        <Name>Claude Event</Name>
    </Event>

</Events>
