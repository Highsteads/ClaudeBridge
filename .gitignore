# Bundled Python packages (installed by Indigo via requirements.txt)
Contents/Packages/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python

# Vector database (auto-generated, contains no source)
*.db
*.sqlite
*.sqlite3

# Secrets — NEVER commit
secrets.py
IndigoSecrets.py
secrets.json
*.key

# Webhook runtime files (hold per-subscription signing keys + bearer tokens).
# These live under Indigo's Preferences dir, not the repo, but ignore them
# defensively so a stray copy can never be committed.
webhooks.json
webhook_allowlist.json

# macOS
.DS_Store
.AppleDouble
.LSOverride

# Indigo runtime files
*.indiPref
*.indiDb

# Editor
.vscode/
.idea/
*.swp
*.swo

# Test runner artefacts
.pytest_cache/

# Logs
*.log

# Claude Code context file — local only
CLAUDE.md

# Published repo = plugin bundle + README + LICENSE + docs + tests/scripts/examples.
# These root-level duplicates / meta files stay LOCAL-ONLY (the canonical copies
# live inside the plugin bundle, or are working notes):
/indigo_mcp_proxy.py
/IndigoSecrets_example.py
/CAPABILITY_SUMMARY.md
/CONTRIBUTING.md
/ruff.toml
.github/
